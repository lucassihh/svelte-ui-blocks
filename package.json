		"@tailwindcss/vite": "^4.1.18",
		"bits-ui": "^2.16.3",
		"clsx": "^2.1.1",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"svelte-meta-tags": "^4.6.0",
