{
	"name": "@sv/cnblocks",
	"version": "0.5.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"links:generate": "node scripts/generate-install-links.mjs",
		"routes:generate:preview": "node scripts/generate-static-preview-routes.mjs",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"build:registry:core": "jsrepo build",
		"build:registry": "yarn shadcn-svelte registry build",
		"ci:release": "jsrepo publish --verbose && changeset tag",
		"create:veil": "node scripts/create-tailark-feature.mjs",
		"lint": "prettier --check .",
		"format": "prettier --write .",
		"replace": "cd ./scripts && python replace.py"
	},
	"devDependencies": {
		"@iconify/svelte": "^5.2.1",
		"@internationalized/date": "^3.10.1",
		"@lucide/svelte": "^0.561.0",
		"@shikijs/langs": "^3.4.2",
		"@shikijs/themes": "^3.4.2",
		"@sveltejs/kit": "^2.16.0",
		"@sveltejs/vite-plugin-svelte": "^5.0.0",
		"@tailwindcss/typography": "^0.5.16",
		"@tailwindcss/vite": "^4.0.7",
		"bits-ui": "^2.15.4",
		"clsx": "^2.1.1",
		"dotted-map": "^2.2.3",
		"jsrepo": "^3.0.5",
		"mode-watcher": "^1.0.6",
		"paneforge": "^0.0.6",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"shiki": "^3.2.1",
		"svelte": "^5.23.0",
		"svelte-check": "^4.2.1",
		"svelte-meta-tags": "^4.3.0",
		"swiper": "^11.2.8",
		"tailwind-merge": "^3.3.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.1.8",
		"typescript": "^5.8.3",
		"velite": "^0.3.1",
		"vite": "^6.0.0"
	},
	"dependencies": {
		"@changesets/cli": "^2.29.4",
		"@sveltejs/adapter-vercel": "^6.3.1",
		"@svitejs/changesets-changelog-github-compact": "^1.2.0",
		"dompurify": "^3.3.0",
		"isomorphic-dompurify": "^3.0.0",
		"marked": "^15.0.12",
		"package-manager-detector": "^1.6.0",
		"runed": "^0.37.1",
		"shadcn-svelte": "^1.1.1",
		"svelte-toolbelt": "^0.10.6",
		"tw-animate-css": "^1.4.0"
	}
}
