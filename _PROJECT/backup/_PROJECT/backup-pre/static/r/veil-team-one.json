ase font-medium\">{member.name}</p>\n\t\t\t\t\t\t\t<p class=\"text-sm text-muted-foreground\">{member.role}</p>\n\t\t\t\t\t\t</div>\n\n\t\t\t\t\t\t<p class=\"text-sm text-balance text-muted-foreground\">\n\t\t\t\t\t\t\t{member.bio}\n\t\t\t\t\t\t</p>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t{/each}\n\t\t</div>\n\t</div>\n</section>\n",
