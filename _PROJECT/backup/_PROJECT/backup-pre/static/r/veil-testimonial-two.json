ded-full before:absolute before:inset-0 before:rounded-full before:border before:border-foreground/10\"\n\t\t\t\t\t>\n\t\t\t\t\t\t<img\n\t\t\t\t\t\t\tsrc={testimonial.avatar}\n\t\t\t\t\t\t\talt={testimonial.name}\n\t\t\t\t\t\t\tclass=\"rounded-full object-cover\"\n\t\t\t\t\t\t\twidth={40}\n\t\t\t\t\t\t\theight={40}\n\t\t\t\t\t\t/>\n\t\t\t\t\t</div>\n\t\t\t\t\t<div class=\"space-y-6\">\n\t\t\t\t\t\t<p class=\"text-lg text-foreground\">{testimonial.quote}</p>\n\n\t\t\t\t\t\t<div class=\"space-y-1\">\n\t\t\t\t\t\t\t<p class=\"text-sm font-medium text-muted-foreground\">\n\t\t\t\t\t\t\t\t{testimonial.name}\n\t\t\t\t\t\t\t</p>\n\t\t\t\t\t\t\t<p class=\"text-xs text-muted-foreground\">{testimonial.role}</p>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t</Card>\n\t\t\t{/each}\n\t\t</div>\n\t</div>\n</section>\n",
