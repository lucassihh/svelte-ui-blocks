			"content": "<script>\n\timport Button from \"$COMPONENTS$/ui/button/button.svelte\";\n\timport Check from \"@lucide/svelte/icons/check\";\n\timport Sparkles from \"@lucide/svelte/icons/sparkles\";\n\timport Star from \"@lucide/svelte/icons/star\";\n\n\tconst tableData = [\n\t\t{\n\t\t\tfeature: \"Feature 1\",\n\t\t\tfree: true,\n\t\t\tpro: true,\n\t\t\tstartup: true,\n\t\t},\n\t\t{\n\t\t\tfeature: \"Feature 2\",\n\t\t\tfree: true,\n\t\t\tpro: true,\n\t\t\tstartup: true,\n\t\t},\n\t\t{\n\t\t\tfeature: \"Feature 3\",\n\t\t\tfree: false,\n\t\t\tpro: true,\n\t\t\tstartup: true,\n\t\t},\n\t\t{\n\t\t\tfeature: \"Tokens\",\n\t\t\tfree: \"\",\n\t\t\tpro: \"20 Users\",\n\t\t\tstartup: \"Unlimited\",\n\t\t},\n\t\t{\n\t\t\tfeature: \"Video calls\",\n\t\t\tfree: \"\",\n\t\t\tpro: \"12 Weeks\",\n\t\t\tstartup: \"56\",\n\t\t},\n\t\t{\n\t\t\tfeature: \"Support\",\n\t\t\tfree: \"\",\n\t\t\tpro: \"Secondes\",\n\t\t\tstartup: \"Unlimited\",\n\t\t},\n\t\t{\n\t\t\tfeature: \"Security\",\n\t\t\tfree: \"\",\n\t\t\tpro: \"20 Users\",\n\t\t\tstartup: \"Unlimited\",\n\t\t},\n\t];\n</script>\n\n<section class=\"bg-muted py-16 [--color-primary:var(--color-indigo-500)] md:py-32 dark:bg-muted/20\">\n\t<div class=\"mx-auto max-w-5xl px-6\">\n\t\t<div class=\"w-full overflow-auto lg:overflow-visible\">\n\t\t\t<table class=\"w-[200vw] border-separate border-spacing-x-3 md:w-full\">\n\t\t\t\t<thead class=\"sticky top-0 bg-muted/95 dark:bg-transparent\">\n\t\t\t\t\t<tr class=\"*:py-4 *:text-left *:font-medium\">\n\t\t\t\t\t\t<th class=\"lg:w-2/5\"></th>\n\t\t\t\t\t\t<th class=\"space-y-3\">\n\t\t\t\t\t\t\t<span class=\"block\">Free</span>\n\n\t\t\t\t\t\t\t<Button variant=\"neutral\">Get Started</Button>\n\t\t\t\t\t\t</th>\n\t\t\t\t\t\t<th class=\"space-y-3\">\n\t\t\t\t\t\t\t<span class=\"block\">Pro</span>\n\t\t\t\t\t\t\t<Button variant=\"mdefault\">Get Started</Button>\n\t\t\t\t\t\t</th>\n\t\t\t\t\t\t<th class=\"space-y-3\">\n\t\t\t\t\t\t\t<span class=\"block\">Startup</span>\n\t\t\t\t\t\t\t<Button variant=\"neutral\">Get Started</Button>\n\t\t\t\t\t\t</th>\n\t\t\t\t\t</tr>\n\t\t\t\t</thead>\n\t\t\t\t<tbody>\n\t\t\t\t\t<tr class=\"*:py-4\">\n\t\t\t\t\t\t<td class=\"flex items-center gap-2 font-medium\">\n\t\t\t\t\t\t\t<Star class=\"size-4\" />\n\t\t\t\t\t\t\t<span>Features</span>\n\t\t\t\t\t\t</td>\n\t\t\t\t\t\t<td></td>\n\t\t\t\t\t\t<td class=\"border-none px-4\"></td>\n\t\t\t\t\t\t<td></td>\n\t\t\t\t\t</tr>\n\t\t\t\t\t{#each tableData.slice(-4) as row}\n\t\t\t\t\t\t<tr class=\"*:border-b *:py-4\">\n\t\t\t\t\t\t\t<td class=\"text-muted-foreground\">{row.feature}</td>\n\t\t\t\t\t\t\t<td>\n\t\t\t\t\t\t\t\t{#if row.free === true}\n\t\t\t\t\t\t\t\t\t<Check class=\"size-3 text-primary\" strokeWidth={3.5} />\n\t\t\t\t\t\t\t\t{:else}\n\t\t\t\t\t\t\t\t\t{row.free}\n\t\t\t\t\t\t\t\t{/if}\n\t\t\t\t\t\t\t</td>\n\t\t\t\t\t\t\t<td>\n\t\t\t\t\t\t\t\t{#if row.pro === true}\n\t\t\t\t\t\t\t\t\t<Check class=\"size-3 text-primary\" strokeWidth={3.5} />\n\t\t\t\t\t\t\t\t{:else}\n\t\t\t\t\t\t\t\t\t{row.pro}\n\t\t\t\t\t\t\t\t{/if}\n\t\t\t\t\t\t\t</td>\n\t\t\t\t\t\t\t<td>\n\t\t\t\t\t\t\t\t{#if row.startup === true}\n\t\t\t\t\t\t\t\t\t<Check class=\"size-3 text-primary\" strokeWidth={3.5} />\n\t\t\t\t\t\t\t\t{:else}\n\t\t\t\t\t\t\t\t\t{row.startup}\n\t\t\t\t\t\t\t\t{/if}\n\t\t\t\t\t\t\t</td>\n\t\t\t\t\t\t</tr>\n\t\t\t\t\t{/each}\n\t\t\t\t\t<tr class=\"*:pt-8 *:pb-4\">\n\t\t\t\t\t\t<td class=\"flex items-center gap-2 font-medium\">\n\t\t\t\t\t\t\t<Sparkles class=\"size-4\" />\n\t\t\t\t\t\t\t<span>AI Models</span>\n\t\t\t\t\t\t</td>\n\t\t\t\t\t\t<td></td>\n\t\t\t\t\t\t<td class=\"border-none bg-muted px-4 dark:bg-transparent\"></td>\n\t\t\t\t\t\t<td></td>\n\t\t\t\t\t</tr>\n\t\t\t\t\t{#each tableData as row}\n\t\t\t\t\t\t<tr class=\"*:border-b *:py-4\">\n\t\t\t\t\t\t\t<td class=\"text-muted-foreground\">{row.feature}</td>\n\t\t\t\t\t\t\t<td>\n\t\t\t\t\t\t\t\t{#if row.free === true}\n\t\t\t\t\t\t\t\t\t<Check class=\"size-3 text-primary\" strokeWidth={3.5} />\n\t\t\t\t\t\t\t\t{/if}\n\t\t\t\t\t\t\t</td>\n\t\t\t\t\t\t\t<td>\n\t\t\t\t\t\t\t\t{#if row.pro === true}\n\t\t\t\t\t\t\t\t\t<Check class=\"size-3 text-primary\" strokeWidth={3.5} />\n\t\t\t\t\t\t\t\t{:else}\n\t\t\t\t\t\t\t\t\t{row.pro}\n\t\t\t\t\t\t\t\t{/if}\n\t\t\t\t\t\t\t</td>\n\t\t\t\t\t\t\t<td>\n\t\t\t\t\t\t\t\t{#if row.startup === true}\n\t\t\t\t\t\t\t\t\t<Check class=\"size-3 text-primary\" strokeWidth={3.5} />\n\t\t\t\t\t\t\t\t{:else}\n\t\t\t\t\t\t\t\t\t{row.startup}\n\t\t\t\t\t\t\t\t{/if}\n\t\t\t\t\t\t\t</td>\n\t\t\t\t\t\t</tr>\n\t\t\t\t\t{/each}\n\t\t\t\t</tbody>\n\t\t\t</table>\n\t\t</div>\n\t</div>\n</section>\n",
