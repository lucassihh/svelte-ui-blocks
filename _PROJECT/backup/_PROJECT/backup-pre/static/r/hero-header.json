an>\n\t\t\t\t\t\t\t\t\t</a>\n\t\t\t\t\t\t\t\t</li>\n\t\t\t\t\t\t\t{/each}\n\t\t\t\t\t\t</ul>\n\t\t\t\t\t</div>\n\t\t\t\t\t<div\n\t\t\t\t\t\tclass=\"flex w-full flex-col space-y-3 sm:flex-row sm:gap-3 sm:space-y-0 md:w-fit\"\n\t\t\t\t\t>\n\t\t\t\t\t\t<Button\n\t\t\t\t\t\t\tvariant=\"outline\"\n\t\t\t\t\t\t\tsize=\"sm\"\n\t\t\t\t\t\t\tclass={cn(isScrolled && \"lg:hidden\")}\n\t\t\t\t\t\t\thref=\"#\"\n\t\t\t\t\t\t>\n\t\t\t\t\t\t\tLogin\n\t\t\t\t\t\t</Button>\n\t\t\t\t\t\t<Button href=\"#\" size=\"sm\" class={cn(isScrolled && \"lg:hidden\")}\n\t\t\t\t\t\t\t>Sign Up</Button\n\t\t\t\t\t\t>\n\t\t\t\t\t\t<Button\n\t\t\t\t\t\t\tsize=\"sm\"\n\t\t\t\t\t\t\thref=\"#\"\n\t\t\t\t\t\t\tclass={cn(isScrolled ? \"lg:inline-flex\" : \"hidden\")}\n\t\t\t\t\t\t>\n\t\t\t\t\t\t\tGet Strated\n\t\t\t\t\t\t</Button>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\t</nav>\n</header>\n",
