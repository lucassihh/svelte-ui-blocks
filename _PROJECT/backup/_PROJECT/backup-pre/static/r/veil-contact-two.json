			"content": "<script lang=\"ts\">\n\timport { Button } from \"$COMPONENTS$/ui/veil/button\";\n\timport { Card } from \"$COMPONENTS$/ui/veil/card\";\n\timport { Input } from \"$COMPONENTS$/ui/veil/input\";\n\timport { Label } from \"$COMPONENTS$/ui/label\";\n\timport * as Select from \"$COMPONENTS$/ui/select\";\n\timport { Textarea } from \"$COMPONENTS$/ui/veil/textarea\";\n</script>\n\n<section class=\"@container bg-background py-24\">\n\t<div class=\"mx-auto max-w-2xl px-6\">\n\t\t<div class=\"text-center\">\n\t\t\t<h1 class=\"font-serif text-4xl font-medium text-balance sm:text-5xl\">Contact Sales</h1>\n\t\t\t<p class=\"mx-auto mt-4 max-w-md text-balance text-muted-foreground\">\n\t\t\t\tReady to get started? Our team will help you find the right plan for your business.\n\t\t\t</p>\n\t\t</div>\n\n\t\t<Card variant=\"outline\" class=\"mt-12 p-8\">\n\t\t\t<form action=\"\" class=\"space-y-5\">\n\t\t\t\t<div class=\"grid gap-4 @md:grid-cols-2\">\n\t\t\t\t\t<div class=\"space-y-2\">\n\t\t\t\t\t\t<Label for=\"firstName\" class=\"text-sm\">First name</Label>\n\t\t\t\t\t\t<Input type=\"text\" id=\"firstName\" name=\"firstName\" placeholder=\"John\" required />\n\t\t\t\t\t</div>\n\t\t\t\t\t<div class=\"space-y-2\">\n\t\t\t\t\t\t<Label for=\"lastName\" class=\"text-sm\">Last name</Label>\n\t\t\t\t\t\t<Input type=\"text\" id=\"lastName\" name=\"lastName\" placeholder=\"Doe\" required />\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\n\t\t\t\t<div class=\"space-y-2\">\n\t\t\t\t\t<Label for=\"email\" class=\"text-sm\">Work email</Label>\n\t\t\t\t\t<Input type=\"email\" id=\"email\" name=\"email\" placeholder=\"you@company.com\" required />\n\t\t\t\t</div>\n\n\t\t\t\t<div class=\"space-y-2\">\n\t\t\t\t\t<Label for=\"company\" class=\"text-sm\">Company</Label>\n\t\t\t\t\t<Input type=\"text\" id=\"company\" name=\"company\" placeholder=\"Acme Inc.\" />\n\t\t\t\t</div>\n\n\t\t\t\t<div class=\"grid gap-4 @md:grid-cols-2\">\n\t\t\t\t\t<div class=\"space-y-2\">\n\t\t\t\t\t\t<Label for=\"size\" class=\"text-sm\">Company size</Label>\n\t\t\t\t\t\t<Select.Root type=\"single\">\n\t\t\t\t\t\t\t<Select.Trigger\n\t\t\t\t\t\t\t\tclass=\"h-8 bg-card shadow-none ring-input focus-visible:ring-ring/15 dark:bg-transparent\"\n\t\t\t\t\t\t\t>\n\t\t\t\t\t\t\t\tSelect\n\t\t\t\t\t\t\t</Select.Trigger>\n\t\t\t\t\t\t\t<Select.Content\n\t\t\t\t\t\t\t\tclass=\"rounded-xl border-transparent ring-1 ring-border\"\n\t\t\t\t\t\t\t>\n\t\t\t\t\t\t\t\t<Select.Item value=\"1-10\">1-10 employees</Select.Item>\n\t\t\t\t\t\t\t\t<Select.Item value=\"11-50\">11-50 employees</Select.Item>\n\t\t\t\t\t\t\t\t<Select.Item value=\"51-200\">51-200 employees</Select.Item>\n\t\t\t\t\t\t\t\t<Select.Item value=\"201-500\">201-500 employees</Select.Item>\n\t\t\t\t\t\t\t\t<Select.Item value=\"500+\">500+ employees</Select.Item>\n\t\t\t\t\t\t\t</Select.Content>\n\t\t\t\t\t\t</Select.Root>\n\t\t\t\t\t</div>\n\n\t\t\t\t\t<div class=\"space-y-2\">\n\t\t\t\t\t\t<Label for=\"interest\" class=\"text-sm\">Interest</Label>\n\t\t\t\t\t\t<Select.Root type=\"single\">\n\t\t\t\t\t\t\t<Select.Trigger\n\t\t\t\t\t\t\t\tclass=\"h-8 bg-card shadow-none ring-input focus-visible:ring-ring/15 dark:bg-transparent\"\n\t\t\t\t\t\t\t>\n\t\t\t\t\t\t\t\tSelect\n\t\t\t\t\t\t\t</Select.Trigger>\n\t\t\t\t\t\t\t<Select.Content\n\t\t\t\t\t\t\t\tclass=\"rounded-xl border-transparent ring-1 ring-border\"\n\t\t\t\t\t\t\t>\n\t\t\t\t\t\t\t\t<Select.Item value=\"pricing\">Pricing</Select.Item>\n\t\t\t\t\t\t\t\t<Select.Item value=\"demo\">Product demo</Select.Item>\n\t\t\t\t\t\t\t\t<Select.Item value=\"partnership\">Partnership</Select.Item>\n\t\t\t\t\t\t\t\t<Select.Item value=\"other\">Other</Select.Item>\n\t\t\t\t\t\t\t</Select.Content>\n\t\t\t\t\t\t</Select.Root>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\n\t\t\t\t<div class=\"space-y-2\">\n\t\t\t\t\t<Label for=\"message\" class=\"text-sm\">Message</Label>\n\t\t\t\t\t<Textarea\n\t\t\t\t\t\tid=\"message\"\n\t\t\t\t\t\tname=\"message\"\n\t\t\t\t\t\trows={5}\n\t\t\t\t\t\tplaceholder=\"Tell us about your needs...\"\n\t\t\t\t\t\tclass=\"min-h-28\"\n\t\t\t\t\t/>\n\t\t\t\t</div>\n\n\t\t\t\t<Button class=\"w-full\" type=\"submit\">Submit</Button>\n\t\t\t</form>\n\t\t</Card>\n\n\t\t<p class=\"mt-6 text-center text-sm text-muted-foreground\">\n\t\t\tBy submitting, you agree to our\n\t\t\t<a href=\"#\" class=\"text-foreground underline\">Privacy Policy</a>\n\t\t</p>\n\t</div>\n</section>\n",
			"type": "registry:component",
			"target": "veil/contact/contact-two.svelte"
		}
