{
	"$schema": "https://shadcn-svelte.com/schema/registry-item.json",
	"name": "veil-pricing-two",
	"type": "registry:block",
	"description": "Veil Pricing component, variant Two.",
	"devDependencies": [
		"@lucide/svelte"
	],
	"registryDependencies": [
		"utils"
