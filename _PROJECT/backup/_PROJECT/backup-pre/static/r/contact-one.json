{
	"$schema": "https://shadcn-svelte.com/schema/registry-item.json",
	"name": "contact-one",
	"type": "registry:block",
	"description": "Contact form with input fields and submit button",
	"registryDependencies": [
		"button",
		"card",
		"input",
		"label",
		"select",
		"textarea"
	],
	"files": [
		{
			"content": "<script>\n\timport Button from \"$COMPONENTS$/ui/button/button.svelte\";\n\timport { Card } from \"$COMPONENTS$/ui/card\";\n\timport Input from \"$COMPONENTS$/ui/input/input.svelte\";\n\timport Label from \"$COMPONENTS$/ui/label/label.svelte\";\n\timport * as Select from \"$COMPONENTS$/ui/select/index.js\";\n\timport { Textarea } from \"$COMPONENTS$/ui/textarea\";\n</script>\n\n<!--\n@component\n\n- A component that displays a contact form.\n\n@example\n```svelte\n<ContactOne />\n```\n\n\n -->\n\n<section class=\"py-32\">\n\t<div class=\"mx-auto max-w-3xl px-8 lg:px-0\">\n\t\t<h1 class=\"text-center text-4xl font-semibold lg:text-5xl\">Contact Sales</h1>\n\t\t<p class=\"mt-4 text-center\">\n\t\t\tWe'll help you find the right plan and pricing for your business.\n\t\t</p>\n\n\t\t<Card class=\"mx-auto mt-12 max-w-lg p-8 shadow-md sm:p-16\">\n\t\t\t<div>\n\t\t\t\t<h2 class=\"text-xl font-semibold\">Let's get you to the right place</h2>\n\t\t\t\t<p class=\"mt-4 text-sm\">\n\t\t\t\t\tReach out to our sales team! We're eager to learn more about how you plan to use\n\t\t\t\t\tour application.\n\t\t\t\t</p>\n\t\t\t</div>\n\n\t\t\t<form action=\"\" class=\"mt-12 space-y-6 *:space-y-3 **:[&>label]:block\">\n\t\t\t\t<div>\n\t\t\t\t\t<Label for=\"name\">Full name</Label>\n\t\t\t\t\t<Input type=\"text\" id=\"name\" placeholder=\"John Doe\" required />\n\t\t\t\t</div>\n\n\t\t\t\t<div>\n\t\t\t\t\t<Label for=\"email\">Work Email</Label>\n\t\t\t\t\t<Input type=\"email\" id=\"email\" placeholder=\"you@company.com\" required />\n\t\t\t\t</div>\n\n\t\t\t\t<div>\n\t\t\t\t\t<Label for=\"country\">Country/Region</Label>\n\t\t\t\t\t<Select.Root type=\"single\">\n\t\t\t\t\t\t<Select.Trigger>Select Country/Region</Select.Trigger>\n\t\t\t\t\t\t<Select.Content>\n\t\t\t\t\t\t\t<Select.Item value=\"1\">DR Congo</Select.Item>\n\t\t\t\t\t\t\t<Select.Item value=\"2\">United States</Select.Item>\n\t\t\t\t\t\t\t<Select.Item value=\"3\">France</Select.Item>\n\t\t\t\t\t\t</Select.Content>\n\t\t\t\t\t</Select.Root>\n\t\t\t\t</div>\n\n\t\t\t\t<div>\n\t\t\t\t\t<Label for=\"website\">Company Website</Label>\n\t\t\t\t\t<Input type=\"url\" id=\"website\" placeholder=\"https://company.com\" />\n\t\t\t\t\t<span class=\"inline-block text-sm text-muted-foreground\"\n\t\t\t\t\t\t>Must start with 'https'</span\n\t\t\t\t\t>\n\t\t\t\t</div>\n\n\t\t\t\t<div>\n\t\t\t\t\t<Label for=\"job\">Job function</Label>\n\t\t\t\t\t<Select.Root type=\"single\">\n\t\t\t\t\t\t<Select.Trigger>Select Job Function</Select.Trigger>\n\t\t\t\t\t\t<Select.Content>\n\t\t\t\t\t\t\t<Select.Item value=\"1\">Finance</Select.Item>\n\t\t\t\t\t\t\t<Select.Item value=\"2\">Education</Select.Item>\n\t\t\t\t\t\t\t<Select.Item value=\"3\">Legal</Select.Item>\n\t\t\t\t\t\t\t<Select.Item value=\"4\">More</Select.Item>\n\t\t\t\t\t\t</Select.Content>\n\t\t\t\t\t</Select.Root>\n\t\t\t\t</div>\n\n\t\t\t\t<div>\n\t\t\t\t\t<Label for=\"msg\">Message</Label>\n\t\t\t\t\t<Textarea id=\"msg\" rows={3} placeholder=\"Tell us about your needs...\" />\n\t\t\t\t</div>\n\n\t\t\t\t<Button>Submit</Button>\n\t\t\t</form>\n\t\t</Card>\n\t</div>\n</section>\n",
			"type": "registry:component",
			"target": "blocks/contact/contact-one.svelte"
		}
	]
}